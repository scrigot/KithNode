{
  "name": "kithnode",
  "version": "1.0.0",
  "description": "AI-driven recruitment networking intelligence platform",
  "engines": {
    "node": ">=22 <26"
  },
  "packageManager": "npm@11.11.0",
  "scripts": {
    "dev": "bash scripts/dev/start-local.sh",
    "dev:live": "bash scripts/dev/start-live.sh",
    "dev:reset": "bash scripts/dev/reset-local.sh",
    "dev:me": "DATABASE_URL='postgresql://postgres:postgres@127.0.0.1:54322/kithnode_me' PERSONAL_MODE=1 ME_USER_EMAIL='samrigot@kithnode.ai' NEXT_PUBLIC_SUPABASE_URL='http://127.0.0.1:54321' next dev -p 3030",
    "me:up": "bash scripts/me/up.sh",
    "me:db:push": "prisma db push --url 'postgresql://postgres:postgres@127.0.0.1:54322/kithnode_me'",
    "me:db:studio": "docker exec -it supabase_db_bangalore psql -U postgres -d kithnode_me",
    "me:import-prod": "tsx scripts/me/import-from-prod.ts",
    "build": "prisma generate && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:professors": "tsx prisma/seed-professors.ts",
    "db:generate": "prisma generate",
    "db:verify": "bash scripts/db/verify-migrations.sh",
    "db:history:check": "node scripts/db/materialize-production-history.mjs --check",
    "db:roadmap-sync": "tsx prisma/sync-roadmap.ts",
    "dev:test-user": "tsx scripts/dev/make-test-user.ts",
    "groupme:pull": "tsx scripts/dev/groupme-pull-once.ts",
    "email:setup": "tsx scripts/email/send-setup.ts",
    "email:log": "tsx scripts/email/log.ts"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.91",
    "@base-ui/react": "^1.3.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.9.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@sentry/nextjs": "^10.53.1",
    "@stripe/stripe-js": "^9.0.1",
    "@supabase/supabase-js": "^2.101.1",
    "@types/three": "^0.184.1",
    "ai": "^6.0.149",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cobe": "^2.0.1",
    "dotenv": "^17.3.1",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "jose": "^6.2.0",
    "lucide-react": "^1.7.0",
    "next": "^16.2.11",
    "next-auth": "^5.0.0-beta.32",
    "pg": "^8.20.0",
    "posthog-js": "^1.359.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-force-graph-2d": "^1.29.1",
    "recharts": "^3.8.1",
    "resend": "^6.11.0",
    "server-only": "0.0.1",
    "stripe": "^22.0.0",
    "svix": "^1.95.2",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prisma": "^7.9.0",
    "shadcn": "^4.14.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "@sentry/bundler-plugin-core": {
      "brace-expansion": "5.0.7"
    },
    "next": {
      "sharp": "0.35.3"
    },
    "posthog-js": {
      "dompurify": "3.4.12"
    },
    "prisma": {
      "fast-uri": "3.1.4"
    },
    "shadcn": {
      "fast-uri": "3.1.4"
    }
  }
}
