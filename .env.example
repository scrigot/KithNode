# KithNode environment variables (example — copy to .env.local, fill in real values).
# Never commit .env.local. These are placeholders only.

# Auth (NextAuth v5 + Google OAuth)
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Founder-ops cockpit gate (/dashboard/ops). Not a secret — an allow-list of one.
# Defaults to samrigot31@gmail.com in code if unset.
FOUNDER_EMAIL=samrigot31@gmail.com

# Supabase (Postgres + service-role server client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Founder notifications (Slack Incoming Webhook) — real-time pings for new access
# requests, feedback, finished onboarding, and subscriptions. Create at
# api.slack.com → Incoming Webhooks. Unset = alerts logged "skipped", never sent.
SLACK_WEBHOOK_URL=

# Enrichment (backend / FastAPI)
HUNTER_API_KEY=

# LinkedIn enrichment (People Data Labs) — real education + grad year by profile URL. Unset = LLM-only enrichment.
PDL_API_KEY=

# Analytics (PostHog)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Backend (FastAPI on Railway) — the frontend calls it via this URL
FASTAPI_URL=

# AI (Vercel AI SDK v6 + AI Gateway)
AI_GATEWAY_API_KEY=

# --- MCP tooling tokens (only if you use a project .mcp.json; see .mcp.json.example) ---
# SUPABASE_ACCESS_TOKEN=
# SENTRY_ACCESS_TOKEN=
# GITHUB_TOKEN=
# FIRECRAWL_API_KEY=
