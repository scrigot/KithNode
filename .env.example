# KithNode environment variables (example — copy to .env.local, fill in real values).
# Never commit .env.local. These are placeholders only.

# Auth (NextAuth v5 + Google OAuth)
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Founder-ops cockpit gate (/dashboard/ops). Not a secret — an allow-list of one.
# Defaults to samrigot31@gmail.com in code if unset.
FOUNDER_EMAIL=samrigot31@gmail.com

# Supabase (Postgres + service-role server client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Enrichment (backend / FastAPI)
HUNTER_API_KEY=

# LinkedIn enrichment (Proxycurl) — real education + grad year by profile URL. Unset = LLM-only enrichment.
PROXYCURL_API_KEY=

# Analytics (PostHog)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
