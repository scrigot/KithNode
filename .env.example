# KithNode environment variables. Copy to .env.local and use placeholders only
# in this file. Required variables are marked REQUIRED; the rest are feature
# scoped and validated when that integration is enabled.

# Core application -----------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=                         # REQUIRED: Postgres connection string
DIRECT_URL=                           # REQUIRED for migrations: direct/session Postgres connection
AUTH_SECRET=                          # REQUIRED: openssl rand -base64 32
ALLOWED_EMAILS=                       # Optional comma-separated beta allowlist

# Auth providers -------------------------------------------------------------
# Google Cloud OAuth "Authorized redirect URIs" must include:
#   http://localhost:3000/api/auth/callback/google
# Production uses the same path beneath the deployed app origin.
GOOGLE_CLIENT_ID=                     # REQUIRED while Google sign-in is enabled
GOOGLE_CLIENT_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=
NEXT_PUBLIC_MICROSOFT_AUTH_ENABLED=false

# Supabase -------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=             # REQUIRED
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY= # Preferred browser key for new projects
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # Legacy compatibility; remove after migration
SUPABASE_SERVICE_ROLE_KEY=            # REQUIRED, server only
SUPABASE_JWT_SECRET=                  # Required only for custom Realtime JWTs

# AI and enrichment ----------------------------------------------------------
AI_GATEWAY_API_KEY=
ANTHROPIC_API_KEY=                    # Optional direct SDK fallback
AI_DEFAULT_MODEL=anthropic/claude-sonnet-5
AI_FAST_MODEL=anthropic/claude-haiku-4.5
AI_FALLBACK_MODEL=
AI_DAILY_BUDGET_USD=10
AI_MAX_RUN_STEPS=8
PDL_API_KEY=
BRAVE_SEARCH_API_KEY=                 # Optional: resolves official company career pages
HUNTER_API_KEY=
APOLLO_API_KEY=

# Stripe ---------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Product email and provider webhooks ---------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_WEBHOOK_SECRET=
CRON_SECRET=

# Analytics and monitoring ---------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Founder operations ---------------------------------------------------------
FOUNDER_EMAIL=
SLACK_WEBHOOK_URL=
GROUPME_TOKEN=
GROUPME_GROUP_ID=
DEV_RESET_SECRET=

# Feature flags --------------------------------------------------------------
ENABLE_KITH_NODES=false
NEXT_PUBLIC_ENABLE_KITH_NODES=false
NEXT_PUBLIC_ENABLE_OUTREACH_DRAFTS=true
INTRO_AUTOSEND=false
ENABLE_CAREER_SKILLS=true
ENABLE_JOB_DISCOVERY=true

# Temporary owner workspace. Remove after /me is consolidated. --------------
PERSONAL_MODE=false
ME_REQUIRE_AUTH=true
ME_USER_EMAIL=
LOCAL_DATABASE_URL=
PROD_OWNER_EMAIL=

# Connected email and calendar accounts ------------------------------------
# Generate the encryption key with: openssl rand -hex 32
# Local OAuth redirects:
#   http://localhost:3000/api/integrations/google/callback
#   http://localhost:3000/api/integrations/microsoft/callback
# Add the same paths beneath NEXT_PUBLIC_APP_URL in each production console.
OAUTH_TOKEN_ENCRYPTION_KEY=           # REQUIRED for connected accounts; server only
GOOGLE_OAUTH_CLIENT_ID=               # Falls back to GOOGLE_CLIENT_ID
GOOGLE_OAUTH_CLIENT_SECRET=           # Falls back to GOOGLE_CLIENT_SECRET
GOOGLE_PUBSUB_VERIFICATION_TOKEN=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_WEBHOOK_CLIENT_STATE=
LOOPS_API_KEY=

# MCP tooling tokens (only for a project .mcp.json) -------------------------
# SUPABASE_ACCESS_TOKEN=
# SENTRY_ACCESS_TOKEN=
# GITHUB_TOKEN=
# FIRECRAWL_API_KEY=
