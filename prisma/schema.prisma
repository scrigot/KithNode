// Private, user-owned copies of the user's LinkedIn profile. `content` is a
// versioned document because LinkedIn exposes many optional/repeating sections
// and adds new section types over time. Every save creates an immutable
// LinkedInProfileRevision before the working copy changes.
model LinkedInProfile {
  id          String   @id @default(cuid())
  userId      String
  name        String   @default("Untitled LinkedIn profile")
  linkedInUrl String   @default("")
  source      String   @default("manual") // manual | json_import | extension | duplicate | restored
  status      String   @default("draft") // draft | current | archived
  isPrimary   Boolean  @default(false)
  docVersion  Int      @default(1)
  content     Json     @default("{}")
  audit       Json     @default("{}")
  score       Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  revisions LinkedInProfileRevision[]

  @@index([userId, updatedAt])
  @@index([userId, status, isPrimary])
}

model LinkedInProfileRevision {
  id            String   @id @default(cuid())
  profileId     String
  userId        String
  version       Int
  content       Json
  audit         Json     @default("{}")
  score         Int      @default(0)
  changeSummary String   @default("")
  source        String   @default("save") // create | save | audit | restore | import
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  profile LinkedInProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, version])
  @@index([userId, createdAt])
  @@index([profileId, createdAt])
}

// Canonical, user-owned job opportunities. Discovery writes only reviewed
// public listing data; application submission is deliberately out of scope.
model Opportunity {
  id              String    @id @default(cuid())
  userId          String
  company         String
  companyKey      String
  role            String
  location        String    @default("")
  workMode        String    @default("") // remote | hybrid | onsite | unknown
  jobUrl          String
  applyUrl        String    @default("")
  source          String    @default("manual") // manual | greenhouse | lever | ashby | jsonld
  externalId      String    @default("")
  description     String    @default("")
  status          String    @default("discovered") // discovered | saved | preparing | applied | assessment | interview | offer | accepted | rejected | withdrawn | archived
  priority        String    @default("medium") // low | medium | high
  opportunityType String    @default("job") // job | internship | co_op | externship | off_cycle | summer_analyst | insight_program | leadership_program
  season          String    @default("")
  notes           String    @default("")
  nextAction      String    @default("")
  nextActionDue   DateTime? @db.Timestamptz(6)
  appliedAt       DateTime? @db.Timestamptz(6)
  archivedAt      DateTime? @db.Timestamptz(6)
  lastActivityAt  DateTime  @default(now()) @db.Timestamptz(6)
  fitScore        Int       @default(0)
  networkScore    Int       @default(0)
  matchReasons    Json      @default("[]")
  sourceFreshAt   DateTime? @db.Timestamptz(6)
  postedAt        DateTime? @db.Timestamptz(6)
  deadline        DateTime? @db.Timestamptz(6)
  resumeId        String?
  organizationId  String?
  details         Json      @default("{}")
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  contacts     OpportunityContact[]
  events       OpportunityEvent[]
  organization Organization?        @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@unique([userId, jobUrl])
  @@index([userId, status, fitScore])
  @@index([userId, opportunityType, status])
  @@index([userId, companyKey])
  @@index([userId, source, externalId])
  @@index([userId, priority, deadline])
  @@index([userId, nextActionDue])
  @@index([userId, lastActivityAt])
  @@index([userId, organizationId])
}

// Canonical user-owned organizations. "Companies" is the employer-focused
// workspace view; schools, clubs, funds, nonprofits, and programs use the same
// identity layer so records across research, contacts, and applications resolve
// to one organization.
model Organization {
  id          String   @id @default(cuid())
  userId      String
  name        String
  nameKey     String
  type        String   @default("company") // company | school | club | fund | nonprofit | program | other
  domain      String   @default("")
  website     String   @default("")
  logoUrl     String   @default("")
  location    String   @default("")
  industry    String   @default("")
  description String   @default("")
  status      String   @default("active") // active | archived
  source      String   @default("manual")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  people       PersonOrganization[]
  applications Opportunity[]

  @@unique([userId, nameKey])
  @@index([userId, type, updatedAt])
  @@index([userId, status, name])
}

model PersonOrganization {
  id               String    @id @default(cuid())
  userId           String
  contactId        String
  organizationId   String
  relationshipType String    @default("employment") // employment | education | membership | recruiting | referral | other
  title            String    @default("")
  isCurrent        Boolean   @default(false)
  startedAt        DateTime? @db.Timestamptz(6)
  endedAt          DateTime? @db.Timestamptz(6)
  source           String    @default("manual")
  confidence       Float     @default(1)
  createdAt        DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, contactId, organizationId, relationshipType, title])
  @@index([userId, contactId])
  @@index([userId, organizationId, isCurrent])
}

// Unified catalog record over resumes, LinkedIn copies, essays, cover letters,
// outreach, and meeting-prep briefs. Existing source records stay authoritative;
// legacyType + legacyId allow a catalog record to point at them without copying
// or deleting source data.
model CareerDocument {
  id          String   @id @default(cuid())
  userId      String
  type        String   @default("custom") // resume | linkedin | essay | cover_letter | outreach | meeting_brief | custom
  title       String
  status      String   @default("draft") // draft | current | archived
  variantType String   @default("") // job | internship | club | school | general
  legacyType  String   @default("")
  legacyId    String   @default("")
  content     Json     @default("{}")
  evidence    Json     @default("[]")
  metadata    Json     @default("{}")
  source      String   @default("manual")
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  revisions CareerDocumentRevision[]
  links     CareerDocumentLink[]

  @@unique([userId, legacyType, legacyId])
  @@index([userId, type, updatedAt])
  @@index([userId, status, updatedAt])
}

model CareerDocumentRevision {
  id            String   @id @default(cuid())
  documentId    String
  userId        String
  version       Int
  content       Json
  evidence      Json     @default("[]")
  changeSummary String   @default("")
  source        String   @default("save")
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  document CareerDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, version])
  @@index([userId, createdAt])
}

model CareerDocumentLink {
  id         String   @id @default(cuid())
  documentId String
  userId     String
  entityType String // application | person | organization
  entityId   String
  relation   String   @default("reference")
  createdAt  DateTime @default(now()) @db.Timestamptz(6)

  document CareerDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId, entityType, entityId, relation])
  @@index([userId, entityType, entityId])
}

model SavedCrmView {
  id        String   @id @default(cuid())
  userId    String
