generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String       @id @default(cuid())
  email              String       @unique
  name               String
  image              String       @default("")
  university         String       @default("")
  highSchool         String       @default("")
  targetIndustry     String       @default("")
  hometown           String       @default("")
  greekOrg           String       @default("")
  targetIndustries   String       @default("")
  targetFirms        String       @default("")
  targetLocations    String       @default("")
  clubs              String       @default("")
  skills             String       @default("")
  major              String       @default("")
  minor              String       @default("")
  concentration      String       @default("")
  degrees            String       @default("")
  pastFirms          String       @default("")
  educations         String       @default("")
  experiences        String       @default("")
  clubMemberships    String       @default("")
  recruitingDate     DateTime?
  graduationYear     Int?
  weeklyGoalTarget   Int          @default(3)
  stripeCustomerId   String?      @default("")
  subscriptionStatus String?      @default("trial")
  subscriptionPlan   String?      @default("")
  trialEndsAt        DateTime?    @default(dbgenerated("(now() + '7 days'::interval)"))
  subscriptionEndsAt DateTime?
  credits                 Int       @default(0)
  creditsMonthlyAllotment Int       @default(0)
  creditsRenewAt          DateTime? @db.Timestamptz(6)
  onboardingGoal          String    @default("")
  onboardingPain          String    @default("")
  onboardingTimeline      String    @default("")
  tutorialDoneAt          DateTime? @db.Timestamptz(6)
  draftTone               String    @default("warm")
  draftLength             String    @default("medium")
  draftSignature          String    @default("")
  draftSubjectStyle       String    @default("casual")
  digestEmailEnabled      Boolean   @default(true)
  followupEmailEnabled    Boolean   @default(true)
  createdAt          DateTime     @default(now())
  connections        Connection[]
}

model AlumniContact {
  id               String          @id @default(cuid())
  name             String
  firmName         String
  title            String
  linkedInUrl      String          @unique @default("")
  university       String
  graduationYear   Int
  education        String          @default("")
  location         String          @default("")
  highSchool       String          @default("")
  clubs            String          @default("")
  passions         String          @default("")
  notes            String          @default("")
  affiliations     String          @default("")
  warmthScore      Float           @default(0)
  tier             String          @default("cold")
  source           String          @default("manual")
  email            String          @default("")
  importedByUserId String          @default("")
  industry         String          @default("")
  seniorityLevel   String          @default("")
  greekOrg         String          @default("")
  personType       String          @default("")
  major            String          @default("")
  minor            String          @default("")
  concentration    String          @default("")
  degrees          String          @default("")
  skills           String          @default("")
  pastFirms        String          @default("")
  hometown         String          @default("")
  track            String          @default("")
  role             String          @default("")
  educations       String          @default("")
  experiences      String          @default("")
  isFriend         Boolean         @default(false)
  speakFrequency   String          @default("")
  lastSpokenAt     DateTime?       @db.Timestamptz(6)
  clubMemberships  String          @default("")
  createdAt        DateTime        @default(now()) @db.Timestamptz(6)
  enrichedAt       DateTime?
  enrichmentSource String          @default("")
  connections      Connection[]
  pipelineEntries  PipelineEntry[]
  discovers        UserDiscover[]
}

model Connection {
  id               String        @id @default(cuid())
  userId           String
  alumniId         String
  strengthScore    Float         @default(0)
  status           String        @default("NEW")
  automationPaused Boolean       @default(false)
  createdAt        DateTime      @default(now())
  user             User          @relation(fields: [userId], references: [id])
  alumni           AlumniContact @relation(fields: [alumniId], references: [id])

  @@unique([userId, alumniId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  contactId String
  action    String
  detail    String   @default("")
  createdAt DateTime @default(now())
}

model PipelineEntry {
  id          String        @id @default(cuid())
  contactId   String
  pipelineId  String?
  stage       String        @default("RESEARCHED")
  notes       String        @default("")
  addedAt     DateTime      @default(now())
  updatedAt   DateTime      @default(now())
  lastTouchAt DateTime?
  userId      String        @default("")
  contact     AlumniContact @relation(fields: [contactId], references: [id])
  pipeline    Pipeline?     @relation(fields: [pipelineId], references: [id])

  @@unique([contactId, userId])
}

model Pipeline {
  id          String          @id @default(cuid())
  userId      String
  name        String
  kind        String // FUNDING | PROFESSORS | WORK | RECRUITING
  stages      Json            @default("[]") // [{ key, label, color, universalPhase }]
  cadenceDays Int? // nurture threshold in days
  createdAt   DateTime        @default(now())
  entries     PipelineEntry[]

  @@index([userId])
}

model UserDiscover {
  id        String        @id @default(cuid())
  userId    String
  contactId String
  rating    String
  createdAt DateTime      @default(now())
  contact   AlumniContact @relation(fields: [contactId], references: [id])
}

// Per-user private edits layered over a shared AlumniContact (Profile/Relationship
// split). Lets a user personalize a pool contact they've added to their network
// without mutating the canonical, globally-unique row. `overrides` is a partial
// JSON map of editable AlumniContact columns; the contacts routes merge it over
// the canonical row for the editing user only. RLS: service-role only.
model ContactOverride {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id")
  contactId String   @map("contact_id")
  overrides Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([userId, contactId])
  @@index([userId])
  @@map("contact_override")
}

model WaitlistSignup {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  email             String
  full_name         String
  university        String
  grad_year         Int
  target_track      String
  linkedin_url      String?
  greek_affiliation String?
  current_prep      String?
  referred_by       String?
  ref_code          String?
  email_status      String   @default("pending") // pending | sent | failed | skipped | unknown
  email_sent_at     DateTime? @db.Timestamptz(6)

  @@map("waitlist_signups")
}

model IntroRequest {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  from_user_id       String
  intermediary_name  String
  intermediary_email String?
  target_contact_id  String
  message            String
  status             String?   @default("pending")
  created_at         DateTime? @default(now()) @db.Timestamptz(6)

  @@map("intro_requests")
}

model PromoCode {
  id              String    @id @default(uuid()) @db.Uuid
  code            String    @unique
  days            Int       @default(7)
  credits         Int       @default(50)
  plan            String    @default("trial")
  note            String    @default("")
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  redeemedByEmail String?
  redeemedAt      DateTime?
}

model UsageEvent {
  id        String   @id @default(uuid()) @db.Uuid
  userEmail String
  action    String
  credits   Int      @default(0)
  costUsd   Decimal  @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  meta      Json     @default("{}")
}

model Feedback {
  id        String   @id @default(uuid()) @db.Uuid
  userEmail String
  page      String   @default("")
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now()) @db.Timestamptz(6)
}

model ContactConnection {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerUserId     String
  contactId       String
  mutualName      String
  mutualSlug      String   @default("")
  mutualKey       String
  mutualContactId String?
  source          String   @default("linkedin_extension")
  createdAt       DateTime @default(now()) @db.Timestamptz(6)

  @@unique([ownerUserId, contactId, mutualKey])
  @@index([ownerUserId, contactId])
  @@index([ownerUserId, mutualContactId])
}

model EmailEvent {
  id        String   @id @default(cuid())
  emailId   String
  type      String
  recipient String
  subject   String?
  payload   Json
  createdAt DateTime @default(now())

  @@index([recipient])
  @@index([emailId])
}

// ─── Founder Cockpit v2 — phased timeline + per-lane roadmap (read-mirror) ────
// These three tables are the cockpit's derived read-mirror of ops/roadmap.md +
// ops/build-log.md. Markdown is canonical; the /kithnode-roadmap sync upserts
// these (one-way). The cockpit is read-only; agents are the only writers.
// No enums (Prisma convention here) — gate/status/lane/kind are validated
// String fields. RLS + a founder-only policy on each table is a MANUAL
// Supabase-dashboard step after `db push` (the Iron Law; service-role bypasses
// RLS so isFounder at the route is the real guard, RLS is defense-in-depth).

// A named timeline phase (e.g. "Beta with 5 users"). Exactly one row should be
// status="active"; it drives the timeline highlight + the next-10 task list.
model Phase {
  id        String      @id @default(cuid())
  name      String
  gate      String // "G0".."G4"
  order     Int         @default(0)
  status    String      @default("planned") // planned | active | done
  startedAt DateTime?   @db.Timestamptz(6)
  doneAt    DateTime?   @db.Timestamptz(6)
  createdAt DateTime    @default(now()) @db.Timestamptz(6)
  milestones Milestone[]

  @@map("phases")
}

// A roadmap task under a phase + lane. Next-10 = next incomplete by order under
// the active phase. Per-lane roadmap = filter by lane.
model Milestone {
  id        String   @id @default(cuid())
  title     String
  lane      String // one of the 8 lane keys (see lane-config.ts)
  phaseId   String?
  gate      String // "G0".."G4"
  status    String   @default("planned") // planned | in_progress | done | at_risk
  order     Int      @default(0)
  note      String?
  evidence  String? // commit / build-log ref
  doneAt    DateTime? @db.Timestamptz(6)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  phase     Phase?   @relation(fields: [phaseId], references: [id])

  @@map("milestones")
}

// A per-lane "recent change" (derived from lane-tagged build-log entries).
model OpsEvent {
  id        String   @id @default(cuid())
  lane      String // one of the 8 lane keys
  kind      String // shipped | learned | decided
  summary   String
  ref       String? // commit / file
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@map("ops_events")
}

// Append-only record of every outbound email (setup, weekly_digest, followup,
// waitlist, feedback). Server-only: written via the service-role/prisma client,
// read from the terminal (`npm run email:log`). RLS is enabled with no client
// policies, so anon/authenticated are denied; the service role bypasses RLS.
model EmailLog {
  id         String   @id @default(cuid())
  userId     String   @default("") // email-as-id; "" for non-user sends (waitlist/feedback)
  toEmail    String
  type       String // "setup" | "weekly_digest" | "followup" | "waitlist" | "feedback"
  subject    String   @default("")
  status     String // "sent" | "failed" | "skipped"
  providerId String   @default("") // Resend message id
  error      String   @default("")
  createdAt  DateTime @default(now()) @db.Timestamptz(6)

  @@index([toEmail])
  @@index([type, createdAt])
}

// ─── Personal Networking OS ("/me" workspace) — ADDITIVE, local-first ──────────
// These Me* tables back the single-player /me workspace (see
// ~/.claude/plans/...zesty-eich.md). They are PURELY ADDITIVE: no existing table
// is altered. They are gated behind PERSONAL_MODE and accessed ONLY via Prisma
// from src/lib/me/** — never the service-role Supabase client (ESLint-enforced).
// userId is the owner's email (matches the rest of the app's userId convention).
// Designed to run against a LOCAL Postgres (supabase start / dev project), never
// prod, while dogfooding.

// The personal contact. A dedicated table (NOT a reuse of AlumniContact) so
// imported LinkedIn rows never need fake placeholder values, dedup is scoped
// per-user (not global), and personal data never lands in the shared contact
// table. `alumniContactId` optionally links a row imported from a prod
// AlumniContact so we can trace provenance.
model MeContact {
  id             String   @id @default(cuid())
  userId         String
  name           String
  firmName       String?
  title          String?
  linkedInUrl    String?
  email          String?
  location       String?
  education      String?
  industry       String?
  seniorityLevel String?
  pastFirms      String?
  notes          String   @default("")
  source         String   @default("manual") // manual | linkedin_csv | prod_import | apollo
  alumniContactId String? // provenance link when imported from a prod AlumniContact row
  connectedOn    DateTime? // LinkedIn "Connected On" date when known
  lastSpokenAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  pipelineEntries MePipelineEntry[]
  memory          MeContactMemory?
  prepBriefs      MePrepBrief[]
  enrichmentNotes MeContactNote[]
  discoveryLeads  MeDiscoveryLead[]
  activities      MeContactActivity[]
  applicationLinks MeApplicationContact[]

  @@unique([userId, linkedInUrl]) // scoped dedup — normalized URL, per-user
  @@index([userId])
  @@index([userId, source])
  @@index([userId, industry])
}

// An org/purpose pipeline in the personal workspace. Seeded: Comfort, Anvil, UNC,
// AI Consulting. `stages` mirrors the existing Pipeline.stages JSON shape
// ([{ key, label, color, universalPhase }]) so the existing board components can
// render it. cadenceDays drives the going-cold rail.
model MePipeline {
  id          String   @id @default(cuid())
  userId      String
  name        String
  kind        String   @default("ORG") // ORG for now; future: PURPOSE, etc.
  stages      Json     @default("[]")
  cadenceDays Int?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  entries MePipelineEntry[]

  @@index([userId])
}

// Per-contact-per-pipeline membership. UNIQUE on (userId, contactId, pipelineId)
// gives multi-pipeline membership (one person can be in Comfort AND UNC) WITHOUT
// touching the prod PipelineEntry table (which is unique on (contactId,userId)).
model MePipelineEntry {
  id          String    @id @default(cuid())
  userId      String
  contactId   String
  pipelineId  String
  stage       String    @default("identified")
  notes       String    @default("")
  lastTouchAt DateTime?
  addedAt     DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  contact  MeContact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  pipeline MePipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@unique([userId, contactId, pipelineId])
  @@index([userId])
  @@index([pipelineId])
  @@index([userId, pipelineId, contactId])
}

// The personal memory layer over a contact (relationship type drives ICP ranking;
// strategic value + action items + notes are free context for coffee-prep).
model MeContactMemory {
  id               String   @id @default(cuid())
  userId           String
  contactId        String   @unique
  relationshipType String   @default("") // "" | buyer | practitioner | ecosystem
  strategicValue   String   @default("")
  actionItems      Json     @default("[]")
  notes            String   @default("")
  updatedAt        DateTime @default(now()) @updatedAt

  contact MeContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, relationshipType])
}

// Cached coffee-chat prep brief. Cache key = contactId + promptVersion + memoryHash
// + contextHash (the meeting/person context + refine instructions). contextHash is
// what stops a stale brief being reused when the meeting context changes.
model MePrepBrief {
  id            String   @id @default(cuid())
  userId        String
  contactId     String
  brief         Json
  model         String   @default("")
  promptVersion String   @default("v1")
  memoryHash    String   @default("")
  contextHash   String   @default("")
  meta          Json? // { meeting: {purpose,time,location}, person, refine: [] }
  createdAt     DateTime @default(now())

  contact MeContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([userId, contactId])
  @@index([userId, contactId, promptVersion, memoryHash, contextHash, createdAt])
}

// Append-only enrichment log behind the Memory chatbot. Raw user/assistant turns
// are stored verbatim; structured facts the extractor pulled go in `extracted`.
// The rolled-up summary lives in MeContactMemory (deterministic merge, never a
// direct model write). Keeping raw notes append-only + extraction structured is
// the guard against poisoning memory (which feeds prep/draft/ranking).
model MeContactNote {
  id        String   @id @default(cuid())
  userId    String
  contactId String
  author    String   @default("user") // user | assistant | extractor
  kind      String   @default("chat") // chat | fact | meeting
  content   String
  extracted Json? // validated facts the extractor pulled from this turn
  createdAt DateTime @default(now())

  contact MeContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([userId, contactId, createdAt])
}

// Append-only relationship activity timeline. This is the operational history:
// connect request, LinkedIn message, email draft/copy, coffee chat, follow-up,
// stage move, manual note, etc. Memory is "what to remember"; activity is "what
// happened and when".
model MeContactActivity {
  id         String   @id @default(cuid())
  userId     String
  contactId  String
  type       String   @default("note")
  title      String
  detail     String   @default("")
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())
  meta       Json     @default("{}")

  contact MeContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([userId, contactId, occurredAt])
  @@index([userId, type, occurredAt])
}

// The /me owner's own profile, used to compute warm-signal overlap against
// contacts (shared school/club/employer/hometown/location). Seeded by the
// prod-import script from prod User prefs; editable via a small settings form.
model MeProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  schools         String   @default("")
  clubs           String   @default("")
  pastFirms       String   @default("")
  hometown        String   @default("")
  location        String   @default("")
  currentWork     String   @default("")
  goals           String   @default("")
  targetRoles     String   @default("")
  targetExpertise String   @default("")
  targetCompanies String   @default("")
  targetLocations String   @default("")
  searchKeywords  String   @default("")
  profileNotes    String   @default("")
  outreachStyle   String   @default("")
  outreachLength  String   @default("")
  outreachSignoff String   @default("")
  outreachPositioning String @default("")
  outreachGoals   String   @default("")
  preferredEmailClient String @default("")
  updatedAt       DateTime @default(now()) @updatedAt
}

// People found during /me discovery before they become real contacts. This is a
// local-only staging table: Sam can research, dismiss, or save into MeContact +
// a pipeline when the person is worth tracking.
model MeDiscoveryLead {
  id             String   @id @default(cuid())
  userId         String
  status         String   @default("researching") // researching | saved | dismissed
  name           String
  firmName       String?
  title          String?
  linkedInUrl    String?
  email          String?
  location       String?
  education      String?
  industry       String?
  notes          String   @default("")
  sourceQuery    String   @default("")
  sourceUrl      String   @default("")
  score          Int      @default(0)
  reasons        Json     @default("[]")
  savedContactId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  savedContact MeContact? @relation(fields: [savedContactId], references: [id], onDelete: SetNull)

  @@unique([userId, linkedInUrl])
  @@index([userId, status])
  @@index([userId, score])
}

// A user's resume draft in the /me builder, plus its most recent recruiter grade.
// content is the structured, editable sections; score/dimensions/notes are the
// last gradeResume() result (the grade is recomputed live as the user edits, and
// persisted on save). Mirrors MeDiscoveryLead's score Int + Json-reasons shape.
//
// RLS: /me runs against a LOCAL Postgres (see src/lib/me/db.ts), so there is no
// prod exposure today. Before this table ever runs against a shared/prod DB, add
// a Supabase RLS policy filtering on userId (per repo convention).
model MeResume {
  id         String   @id @default(cuid())
  userId     String
  title      String   @default("Untitled resume")
  track      String   @default("ai-consulting") // ai-consulting | ai-engineering | ai-generalist
  templateId String   @default("dense")
  content    Json     @default("{}") // structured editable sections (ResumeContent)
  score       Int      @default(0)
  dimensions  Json     @default("[]") // last GradedResume.dimensions
  notes       Json     @default("[]") // LLM qualitative notes / bullet rewrites
  docVersion  Int      @default(1)    // schema version of `content` (1=fixed fields, 2=sections[])
  userContext String   @default("")   // free-text "what I've done / who I am" for tailored rewrites
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  applications MeInternshipApplication[]

  @@index([userId, updatedAt])
}

// Internship/job application tracker for the /me workspace. Manual-first,
// spreadsheet-like CRM rows with links to saved resumes and networking contacts.
model MeInternshipApplication {
  id              String    @id @default(cuid())
  userId          String
  company         String
  role            String
  location        String    @default("")
  season          String    @default("")
  jobUrl          String    @default("")
  source          String    @default("")
  deadline        DateTime?
  status          String    @default("interested")
  priority        String    @default("medium")
  resumeId        String?
  jobDescription  String    @default("")
  notes           String    @default("")
  nextAction      String    @default("")
  nextActionDue   DateTime?
  appliedAt       DateTime?
  archived        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  resume  MeResume? @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  contacts MeApplicationContact[]
  events   MeApplicationEvent[]

  @@index([userId, status])
  @@index([userId, deadline])
  @@index([userId, nextActionDue])
  @@index([userId, company])
  @@index([userId, resumeId])
}

model MeApplicationContact {
  id            String   @id @default(cuid())
  userId        String
  applicationId String
  contactId     String
  createdAt     DateTime @default(now())

  application MeInternshipApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  contact     MeContact               @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([userId, applicationId, contactId])
  @@index([userId, applicationId])
  @@index([userId, contactId])
}

model MeApplicationEvent {
  id            String   @id @default(cuid())
  userId        String
  applicationId String
  type          String   @default("note")
  title         String
  detail        String   @default("")
  meta          Json     @default("{}")
  createdAt     DateTime @default(now())

  application MeInternshipApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([userId, applicationId, createdAt])
  @@index([userId, type, createdAt])
}

// Reusable, user-scoped "evidence bank": the real things the user has done. AI
// bullet rewrites must CITE evidence by id and may not fabricate beyond it. Shared
// across all of a user's resumes (not per-resume) so the bank is built once.
model MeEvidence {
  id        String   @id @default(cuid())
  userId    String
  kind      String   @default("project") // project | class | work | leadership | metric | skill
  title     String
  detail    String   @default("")
  metric    String   @default("") // quantified outcome, if any
  proofUrl  String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([userId, kind])
}
