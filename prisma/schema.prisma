// Append-only activity history for the canonical application tracker.
// Server routes scope every read and write by the authenticated UUID.
model OpportunityEvent {
  id            String   @id @default(cuid())
  userId        String
  opportunityId String
  type          String   @default("note")
  title         String
  detail        String   @default("")
  meta          Json     @default("{}")
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([userId, opportunityId, createdAt])
  @@index([userId, type, createdAt])
}

// Per-user mapping from a target firm to its verified public careers source.
model JobSource {
  id            String    @id @default(cuid())
  userId        String
  company       String
  companyKey    String
  provider      String // greenhouse | lever | ashby | jsonld
  boardToken    String    @default("")
  careerUrl     String
  feedUrl       String    @default("")
  active        Boolean   @default(true)
  lastCheckedAt DateTime? @db.Timestamptz(6)
  lastError     String    @default("")
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(6)

  @@unique([userId, companyKey, provider])
  @@index([userId, active, updatedAt])
}

// Revocable bearer credentials used by the unpacked browser extension. Only a
// SHA-256 hash is stored; the raw token is returned once at creation.
model ExtensionToken {
  id         String    @id @default(cuid())
  userId     String
  name       String    @default("Chrome extension")
  tokenHash  String    @unique
  scopes     String    @default("contacts:write profiles:write")
  expiresAt  DateTime? @db.Timestamptz(6)
  revokedAt  DateTime? @db.Timestamptz(6)
  lastUsedAt DateTime? @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)

  @@index([userId, revokedAt, createdAt])
}

// A private, user-owned research handoff. The web research desk and the
// unpacked companion both write the same source-neutral draft shape; only the
// signed-in web workspace may commit it into the network.
model ResearchDraft {
  id             String    @id @default(cuid())
  userId         String
  status         String    @default("draft") // draft | ready | committed | discarded
  sourceType     String    @default("manual") // manual | linkedin_manual | company_page | conversation
  sourceUrl      String    @default("")
  target         Json      @default("{}")
  payload        Json      @default("{}")
  selectedFields Json      @default("[]")
  contactId      String?
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(6)
  committedAt    DateTime? @db.Timestamptz(6)

  @@index([userId, status, updatedAt])
  @@index([userId, contactId])
}

// Append-only field provenance for contact enrichment and reviewed extension
// captures. This keeps provider facts separate from inference and manual edits.
model ContactFieldProvenance {
  id         String   @id @default(cuid())
  userId     String
  contactId  String
  field      String
  source     String // pdl | model_inference | manual | linkedin_extension
  value      Json
  confidence Float    @default(1)
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)

  @@index([userId, contactId, field, createdAt])
  @@index([userId, source, createdAt])
}
