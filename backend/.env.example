# Database — set DATABASE_URL for Postgres, or KITHNODE_DB_PATH for SQLite fallback
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
KITHNODE_DB_PATH=./data/outreach.db

# API Keys (from cold-outreach-bot)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
HUNTER_API_KEY=
APOLLO_API_KEY=

# CORS
CORS_ORIGINS=http://localhost:3000

# Required on every non-health request from the Next.js server. Generate with:
# openssl rand -hex 32
INTERNAL_API_SECRET=

# Server
HOST=0.0.0.0
PORT=8000
