{
  "crons": [
    {
      "path": "/api/digest",
      "schedule": "0 13 * * 1"
    }
  ],
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend"
    }
  }
}
