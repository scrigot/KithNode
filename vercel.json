{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend"
    }
  },
  "crons": [
    { "path": "/api/digest", "schedule": "0 13 * * 1" },
    { "path": "/api/cron/followups", "schedule": "0 13 * * 1,4" }
  ]
}
