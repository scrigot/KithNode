{
  "manifest_version": 3,
  "name": "KithNode Research Companion",
  "version": "0.4.0",
  "description": "A private research notebook that hands reviewed facts to KithNode for final approval.",
  "permissions": ["storage", "sidePanel", "tabs"],
  "host_permissions": [
    "https://kithnode.ai/*",
    "https://*.kithnode.ai/*",
    "http://localhost:3000/*"
  ],
  "background": { "service_worker": "background.js" },
  "side_panel": { "default_path": "panel.html" },
  "action": { "default_title": "Open KithNode Research Companion" }
}
